# ═══════════════════════════════════════════════════════
# NEXALIE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne JAMAIS commiter .env.local
# ═══════════════════════════════════════════════════════

# ── ANTHROPIC (obligatoire) ─────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── SUPABASE (obligatoire pour l'authentification) ──────
# https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Pour les webhooks (ne pas exposer côté client)

# ── STRIPE (paiements France) ────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...           # ou sk_test_... en développement
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...         # Dans Stripe → Webhooks → endpoint secret

# ── RESEND (emails transactionnels) ─────────────────────
# https://resend.com
RESEND_API_KEY=re_...

# ── ANALYTICS (optionnel) ────────────────────────────────
# Google Analytics 4 : https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel : https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=1234567890

# ── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # En prod : https://nexali.ai
